# Server Port
PORT=5000

# ─── MongoDB Configuration ────────────────────
# Replace with your MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name
MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/intellihire?retryWrites=true&w=majority

# ─── JWT Configuration ────────────────────────
# Use a strong, random secret key for production
JWT_SECRET=your_long_random_jwt_secret_key_here

# ─── Judge0 Code Execution API ────────────────
# Option 1: Free public Judge0 instance (default)
JUDGE0_API_URL=https://ce.judge0.com

# Option 2: Self-hosted Judge0 via Docker
# JUDGE0_API_URL=http://localhost:2358

# Option 3: RapidAPI Judge0 (paid service)
# JUDGE0_API_KEY=your_rapidapi_key_here
# JUDGE0_API_HOST=judge0-ce.p.rapidapi.com

# ─── Email Configuration ──────────────────────
# For sending feedback emails and notifications
# If using Gmail, generate an App Password (not your regular password)
# https://myaccount.google.com/apppasswords
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# ─── Frontend URL ─────────────────────────────
# URL where your client application is hosted (production: https://your-app.vercel.app or custom domain)
FRONTEND_URL=http://localhost:5173

# Extra allowed CORS / Socket.io origins (comma-separated). Use for www vs apex, or multiple deploy previews.
# ALLOWED_ORIGINS=https://www.example.com,https://example.com

# ─── Additional Services (Optional) ────────────
# Redis URL for caching and session management
REDIS_URL=redis://localhost:6379

# Node environment
NODE_ENV=development
