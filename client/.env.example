# Client-side environment variables

# API base URL:
# - Leave unset (or non-absolute) to use `/api` — Vite proxy (dev) or Vercel rewrites (prod).
#   Required for same-origin cookies + reliable auth on Vercel (any domain).
# - Set to an absolute URL only for a true cross-origin API (e.g. http://localhost:5000/api
#   when not using the Vite proxy). Do NOT set this to your Render URL when the frontend
#   uses Vercel `vercel.json` rewrites to that API.
# VITE_API_BASE_URL=http://localhost:5000/api
# Point to your backend server (for Socket.io)
VITE_API_URL=http://localhost:5000

# ─── Application Environment ──────────────────
# Options: development, production
VITE_APP_ENV=development
