{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://intellihire-server-7u68.onrender.com/api/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://intellihire-server-7u68.onrender.com/socket.io/$1"
    },
    {
      "source": "/((?!api|socket\\.io).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}


